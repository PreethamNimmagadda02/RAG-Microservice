# DeepInfra API Key (required for both embeddings and LLM generation)
DEEPINFRA_API_KEY=your-deepinfra-api-key-here

# Server configuration
PORT=3000

# Embeddings and LLM both run via DeepInfra API
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# RAG defaults
TOP_K_DEFAULT=3
MIN_SCORE=0.4

# Rate limiting (per IP)
RATE_LIMIT_QUERY_WINDOW_MS=60000
RATE_LIMIT_QUERY_MAX=20
RATE_LIMIT_INGEST_WINDOW_MS=60000
RATE_LIMIT_INGEST_MAX=5
